# Copy to .env for local runs. In GitHub Actions, set these as Secrets/Variables instead.

# --- Instagram (required to publish) ---
# Your Instagram Business account's user ID (numeric).
IG_USER_ID=

# A long-lived access token with instagram_business_content_publish.
# By default this should be an Instagram Login API token (starts with "IGA...").
IG_ACCESS_TOKEN=

# Optional: Graph API version. Defaults to v22.0. Bump if Meta deprecates it.
IG_API_VERSION=v22.0

# Optional: Instagram API host. Defaults to the Instagram API with Instagram
# Login (graph.instagram.com) for "IGA..." tokens. If you use a Facebook Graph
# API token instead (starts with "EAA..."), set this to https://graph.facebook.com.
# The hashtag scout requires the graph.facebook.com path.
IG_GRAPH_HOST=https://graph.instagram.com

# Optional: base URL for relative media paths in the queue (e.g. a Supabase public bucket).
# If set, a queue media_url of "media/photo.jpg" becomes MEDIA_BASE_URL/media/photo.jpg.
MEDIA_BASE_URL=

# --- Anthropic (required only for caption generation) ---
ANTHROPIC_API_KEY=
# Optional: model for caption drafting. Defaults to claude-sonnet-5.
# Use claude-haiku-4-5-20251001 for cheaper, faster drafts.
ANTHROPIC_MODEL=claude-sonnet-5
